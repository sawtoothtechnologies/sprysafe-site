---
// The hero artifact. Built in real HTML/CSS so it can become the actual
// product template later. Always labeled as an illustrative sample.
---

<figure class="report" aria-label="Sample monthly Resilience Report (illustrative)">
  <p class="report__sample">Sample report — illustrative</p>

  <header class="report__head">
    <div>
      <p class="report__title">Margaret's Resilience Report</p>
      <p class="report__month">June</p>
    </div>
    <div class="report__status" role="img" aria-label="Status: mostly strong, improving since March">
      <span class="report__status-label" aria-hidden="true">Status</span>
      <span class="report__status-pill" aria-hidden="true">Mostly strong</span>
      <span class="report__status-sub" aria-hidden="true">▲ improving since March</span>
    </div>
  </header>

  <p class="report__headline">Spotted <strong>4 of 5</strong> practice scams this month</p>

  <ul class="report__list">
    <li>
      <span class="report__what">Fake bank “account locked” email</span>
      <span class="report__result report__result--ok"><i class="report__mark report__mark--ok">✓</i> reported</span>
    </li>
    <li>
      <span class="report__what">Prize-sweepstakes email</span>
      <span class="report__result report__result--ok"><i class="report__mark report__mark--ok">✓</i> deleted</span>
    </li>
    <li>
      <span class="report__what">Fake delivery text</span>
      <span class="report__result report__result--ok"><i class="report__mark report__mark--ok">✓</i> ignored</span>
    </li>
    <li>
      <span class="report__what">Utility “past-due” email</span>
      <span class="report__result report__result--ok"><i class="report__mark report__mark--ok">✓</i> reported</span>
    </li>
    <li>
      <span class="report__what">Fake bank text</span>
      <span class="report__result report__result--warn"><i class="report__mark report__mark--warn">!</i> coached, 30 sec</span>
    </li>
  </ul>

  <p class="report__briefings">Plus: briefed on the <strong>3 newest scams</strong> in circulation this month</p>

  <footer class="report__foot">
    <strong>What we're reinforcing next month:</strong> spotting look-alike sender numbers in texts.
  </footer>
</figure>

<script>
  // Bring the report to life when it scrolls into view: drill rows tick in
  // one by one, then the status pill pops. Progressive enhancement: markup
  // ships the final state, so no-JS and reduced-motion users see everything.
  const reports = Array.from(document.querySelectorAll('.report'));
  const reduceMotionPref = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reports.length && 'IntersectionObserver' in window && !reduceMotionPref) {
    reports.forEach((r) => r.classList.add('report--anim'));
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('report--play');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.35 }
    );
    reports.forEach((r) => io.observe(r));
  }
</script>

<style>
  .report {
    margin: 0;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 30px 30px 26px;
    box-shadow: var(--shadow-lg);
    max-width: 480px;
    font-size: 1rem;
  }
  .report__sample {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    background: var(--paper);
    display: inline-block;
    padding: 4px 12px;
    border-radius: 999px;
    margin: 0 0 18px;
  }
  .report__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 6px;
  }
  .report__title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--pine-deep);
    margin: 0;
    line-height: 1.2;
  }
  .report__month { color: var(--ink-soft); margin: 2px 0 0; }

  /* Qualitative status block */
  .report__status { text-align: right; flex: none; display: grid; gap: 4px; justify-items: end; }
  .report__status-label {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .report__status-pill {
    background: var(--pine);
    color: var(--cream);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    padding: 7px 15px;
    border-radius: 999px;
    white-space: nowrap;
  }
  .report__status-sub {
    font-size: 0.76rem;
    font-weight: 700;
    color: var(--ok);
  }

  .report__headline {
    font-size: 1.1rem;
    margin: 12px 0 14px;
    color: var(--ink);
  }

  /* Drill rows: short label left, big verdict right */
  .report__list {
    list-style: none;
    margin: 0 0 14px;
    padding: 0;
    display: grid;
  }
  .report__list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    padding: 9px 0;
    border-bottom: 1px solid var(--paper);
  }
  .report__list li:last-child { border-bottom: none; }
  .report__what { color: var(--ink); line-height: 1.35; }
  .report__result {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-weight: 700;
  }
  .report__result--ok { color: var(--ok); }
  .report__result--warn { color: var(--warn); }
  .report__mark {
    font-style: normal;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-weight: 800;
    font-size: 1rem;
  }
  .report__mark--ok { background: #e2efe6; color: var(--ok); }
  .report__mark--warn { background: #fbeed3; color: var(--warn); }

  .report__briefings {
    font-size: 0.92rem;
    color: var(--ink-soft);
    background: var(--paper);
    border-radius: 10px;
    padding: 10px 14px;
    margin: 0 0 16px;
  }
  .report__briefings strong { color: var(--pine-deep); }

  .report__foot {
    border-top: 1px solid var(--line);
    padding-top: 14px;
    font-size: 0.95rem;
    color: var(--ink-soft);
  }
  .report__foot strong { color: var(--pine-deep); }

  /* ---------- Scroll-in animation ----------
     .report--anim is added by JS only when motion is allowed, so the armed
     (hidden) states below never apply for no-JS or reduced-motion visitors.
     .report--play triggers the sequence when the card enters the viewport. */
  .report--anim .report__headline,
  .report--anim .report__list li,
  .report--anim .report__briefings,
  .report--anim .report__status-pill,
  .report--anim .report__status-sub {
    opacity: 0;
  }
  .report--play .report__headline {
    animation: reportRise 0.5s cubic-bezier(0.22, 0.61, 0.36, 1) 0.15s forwards;
  }
  .report--play .report__list li {
    animation: reportRise 0.45s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
  }
  .report--play .report__list li:nth-child(1) { animation-delay: 0.35s; }
  .report--play .report__list li:nth-child(2) { animation-delay: 0.55s; }
  .report--play .report__list li:nth-child(3) { animation-delay: 0.75s; }
  .report--play .report__list li:nth-child(4) { animation-delay: 0.95s; }
  .report--play .report__list li:nth-child(5) { animation-delay: 1.15s; }
  .report--play .report__mark {
    animation: markIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) backwards;
  }
  .report--play li:nth-child(1) .report__mark { animation-delay: 0.5s; }
  .report--play li:nth-child(2) .report__mark { animation-delay: 0.7s; }
  .report--play li:nth-child(3) .report__mark { animation-delay: 0.9s; }
  .report--play li:nth-child(4) .report__mark { animation-delay: 1.1s; }
  .report--play li:nth-child(5) .report__mark { animation-delay: 1.3s; }
  .report--play .report__briefings {
    animation: reportRise 0.45s cubic-bezier(0.22, 0.61, 0.36, 1) 1.45s forwards;
  }
  .report--play .report__status-pill {
    animation: statusPop 0.5s cubic-bezier(0.34, 1.4, 0.64, 1) 1.6s forwards;
  }
  .report--play .report__status-sub {
    animation: reportRise 0.4s ease 1.85s forwards;
  }
  @keyframes reportRise {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: none; }
  }
  @keyframes statusPop {
    from { opacity: 0; transform: scale(0.6); }
    to { opacity: 1; transform: scale(1); }
  }
  @keyframes markIn {
    from { transform: scale(0); }
    to { transform: scale(1); }
  }

  @media (max-width: 420px) {
    .report__list li { flex-wrap: wrap; gap: 6px; }
    .report__result { margin-left: auto; }
  }
</style>

---
// The hero artifact. Built in real HTML/CSS so it can become the actual
// product template later. Always labeled as an illustrative sample.
---

<figure class="report" aria-label="Sample monthly Resilience Report (illustrative)">
  <p class="report__sample">Sample report — illustrative</p>

  <header class="report__head">
    <div>
      <p class="report__title">Margaret's Resilience Report</p>
      <p class="report__month">June</p>
    </div>
    <div class="report__score" role="img" aria-label="Resilience score 84, up 9 points since March">
      <span class="report__score-num" data-score="84" aria-hidden="true">84</span>
      <span class="report__score-delta" aria-hidden="true">▲ 9 pts since March</span>
    </div>
  </header>

  <p class="report__headline">Spotted <strong>4 of 5</strong> practice scams this month</p>

  <ul class="report__list">
    <li><span class="report__mark report__mark--ok">✓</span> Fake bank “account locked” email — <em>reported it</em></li>
    <li><span class="report__mark report__mark--ok">✓</span> Prize-sweepstakes email — <em>deleted</em></li>
    <li><span class="report__mark report__mark--ok">✓</span> Fake delivery text — <em>ignored</em></li>
    <li><span class="report__mark report__mark--ok">✓</span> Utility “past-due” email — <em>reported it</em></li>
    <li><span class="report__mark report__mark--warn">!</span> Fake bank text — <em>clicked, then completed a 30-second coaching moment</em></li>
  </ul>

  <footer class="report__foot">
    <strong>What we're reinforcing next month:</strong> spotting look-alike sender numbers in texts.
  </footer>
</figure>

<script>
  // Bring the report to life when it scrolls into view: the score counts up,
  // the delta pops in, and the drill results tick in one by one.
  // Progressive enhancement: markup ships the final state, so no-JS visitors
  // and reduced-motion users always see the complete report.
  const reports = Array.from(document.querySelectorAll('.report'));
  const reduceMotionPref = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reports.length && 'IntersectionObserver' in window && !reduceMotionPref) {
    const play = (report) => {
      report.classList.add('report--play');
      const num = report.querySelector('[data-score]');
      if (num) {
        const target = parseInt(num.dataset.score || '0', 10);
        const duration = 1200;
        let startTime;
        const tick = (now) => {
          if (startTime === undefined) startTime = now;
          const progress = Math.min((now - startTime) / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          num.textContent = String(Math.round(target * eased));
          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }
    };

    reports.forEach((r) => r.classList.add('report--anim'));
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            play(entry.target);
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.35 }
    );
    reports.forEach((r) => io.observe(r));
  }
</script>

<style>
  .report {
    margin: 0;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 30px 30px 26px;
    box-shadow: var(--shadow-lg);
    max-width: 480px;
    font-size: 1rem;
  }
  .report__sample {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    background: var(--paper);
    display: inline-block;
    padding: 4px 12px;
    border-radius: 999px;
    margin: 0 0 18px;
  }
  .report__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 6px;
  }
  .report__title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--pine-deep);
    margin: 0;
    line-height: 1.2;
  }
  .report__month { color: var(--ink-soft); margin: 2px 0 0; }
  .report__score { text-align: center; flex: none; }
  .report__score-num {
    display: grid;
    place-items: center;
    width: 74px;
    height: 74px;
    border-radius: 50%;
    background: var(--pine);
    color: var(--cream);
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
  }
  .report__score-delta {
    display: block;
    margin-top: 6px;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--ok);
  }
  .report__headline {
    font-size: 1.1rem;
    margin: 10px 0 16px;
    color: var(--ink);
  }
  .report__list {
    list-style: none;
    margin: 0 0 18px;
    padding: 0;
    display: grid;
    gap: 10px;
  }
  .report__list li {
    display: flex;
    gap: 12px;
    align-items: baseline;
    line-height: 1.45;
    color: var(--ink-soft);
  }
  .report__list em { font-style: normal; color: var(--ink); }
  .report__mark {
    flex: none;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-weight: 700;
    font-size: 0.85rem;
    transform: translateY(4px);
  }
  .report__mark--ok { background: #e2efe6; color: var(--ok); }
  .report__mark--warn { background: #fbeed3; color: var(--warn); }
  .report__foot {
    border-top: 1px solid var(--line);
    padding-top: 14px;
    font-size: 0.95rem;
    color: var(--ink-soft);
  }
  .report__foot strong { color: var(--pine-deep); }

  /* ---------- Scroll-in animation ----------
     .report--anim is added by JS only when motion is allowed, so the armed
     (hidden) states below never apply for no-JS or reduced-motion visitors.
     .report--play triggers the sequence when the card enters the viewport. */
  .report--anim .report__score-delta,
  .report--anim .report__list li,
  .report--anim .report__headline {
    opacity: 0;
  }
  .report--play .report__headline {
    animation: reportRise 0.5s cubic-bezier(0.22, 0.61, 0.36, 1) 0.15s forwards;
  }
  .report--play .report__list li {
    animation: reportRise 0.45s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
  }
  .report--play .report__list li:nth-child(1) { animation-delay: 0.35s; }
  .report--play .report__list li:nth-child(2) { animation-delay: 0.55s; }
  .report--play .report__list li:nth-child(3) { animation-delay: 0.75s; }
  .report--play .report__list li:nth-child(4) { animation-delay: 0.95s; }
  .report--play .report__list li:nth-child(5) { animation-delay: 1.15s; }
  .report--play .report__score-delta {
    animation: deltaPop 0.5s cubic-bezier(0.34, 1.4, 0.64, 1) 1.25s forwards;
  }
  .report--play .report__mark {
    animation: markIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1) backwards;
  }
  .report--play li:nth-child(1) .report__mark { animation-delay: 0.5s; }
  .report--play li:nth-child(2) .report__mark { animation-delay: 0.7s; }
  .report--play li:nth-child(3) .report__mark { animation-delay: 0.9s; }
  .report--play li:nth-child(4) .report__mark { animation-delay: 1.1s; }
  .report--play li:nth-child(5) .report__mark { animation-delay: 1.3s; }
  @keyframes reportRise {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: none; }
  }
  @keyframes deltaPop {
    from { opacity: 0; transform: scale(0.6); }
    to { opacity: 1; transform: scale(1); }
  }
  @keyframes markIn {
    from { transform: translateY(4px) scale(0); }
    to { transform: translateY(4px) scale(1); }
  }
</style>

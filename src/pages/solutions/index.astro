---
import Base from '../../layouts/Base.astro';
import CtaBand from '../../components/CtaBand.astro';
---

<Base
  title="Solutions — Spry for Senior Living, Home Care & Advisors"
  description="If you serve older adults, Spry gives you a provable answer to the question every family is quietly asking: will you keep my parent safe?"
>
  <section class="section">
    <div class="wrap prose">
      <p class="kicker">Solutions</p>
      <h1>The people families trust, made more trustworthy.</h1>
      <p class="lede">
        Spry is built for families — and for the organizations they rely on. If you serve
        older adults, Spry gives you something rare: a <em>provable</em> answer to the
        question every family is quietly asking — “will you keep my parent safe?”
      </p>
      <p>
        <strong>White-glove pilot programs now open for a limited number of founding partners.</strong>
      </p>
    </div>
  </section>

  <section class="section--tight section" style="padding-bottom: 96px;">
    <div class="wrap">
      <div class="grid grid--2">
        <div class="card">
          <h3>Senior-living communities</h3>
          <p>
            The move-in differentiator the community down the street can't claim — with a monthly
            Resilience Report families love.
          </p>
          <p><a class="cta-link" href="/solutions/senior-living">For senior living →</a></p>
        </div>
        <div class="card">
          <h3>Home-care agencies</h3>
          <p>
            A safety add-on your client families will thank you for — deeper trust and a new
            recurring revenue line.
          </p>
          <p><a class="cta-link" href="/solutions/home-care">For home care →</a></p>
        </div>
        <div class="card">
          <h3>Financial &amp; wealth advisors</h3>
          <p>
            Protect the person, not just the portfolio — reduce risk, retain assets, and build
            whole-family relationships for about $60 per client per year.
          </p>
          <p><a class="cta-link" href="/solutions/financial-advisors">For advisors →</a></p>
        </div>
        <div class="card">
          <h3>Credit unions</h3>
          <p>
            A member benefit that keeps savings where they belong — and turns fraud prevention
            into loyalty across generations.
          </p>
          <p><a class="cta-link" href="/solutions/credit-unions">For credit unions →</a></p>
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    headline="Become a founding partner."
    body="A 20-minute call is enough to see whether Spry fits your community, agency, or practice."
    cta="Book a 20-minute call"
    href="mailto:hello@sawtoothtechnologies.com?subject=Spry%20partner%20call"
  />
</Base>

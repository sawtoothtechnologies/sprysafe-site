---
import Base from '../../layouts/Base.astro';
import CtaBand from '../../components/CtaBand.astro';
import OrgPricing from '../../components/OrgPricing.astro';

// Audience order matches the rotating hero. Each has an anchor id for deep links.
const audiences = [
  {
    id: 'financial-advisors',
    name: 'Financial advisors',
    hook: 'Protect the person, not just the portfolio.',
    body: 'You can diversify away market risk — not one convincing phone call. Spry trains your older clients to catch scams before money moves, so you reduce risk, retain assets, and build relationships with the whole family. About $60 per client a year.',
  },
  {
    id: 'credit-unions',
    name: 'Credit unions',
    hook: 'Protect the member, not just the account.',
    body: 'Every scammed member costs you twice — drained deposits, then the fraud-ops hours and shaken trust. Spry works upstream of transaction monitoring, training members to hang up before anything moves. Nothing for branch staff to run.',
  },
  {
    id: 'home-care',
    name: 'Home-care agencies',
    hook: 'The safety add-on client families thank you for.',
    body: "You're already the trusted safety layer in your clients' lives. Spry extends that trust to the threat that arrives by phone — a co-branded protection families value, and a new recurring revenue line, with zero clinical burden on caregivers.",
  },
  {
    id: 'wealth-advisors',
    name: 'Wealth advisors',
    hook: 'The bridge to the next generation.',
    body: 'More than 12,400 older Americans each lost $100k+ to fraud in 2025 — retirement-sized losses no allocation survives. Every month, a co-branded Resilience Report reaches the heirs (nine in ten of whom leave the parents’ advisor), with your firm’s name on the good news.',
  },
  {
    id: 'senior-living',
    name: 'Senior-living communities',
    hook: "The move-in differentiator down the street can't claim.",
    body: 'Every community sells the same amenities. Spry lets you sell what families actually lose sleep over — and prove it every month with a family report and a marketing-able stat: “our residents caught 87% of simulated scams this quarter.”',
  },
  {
    id: 'banks',
    name: 'Community banks',
    hook: 'Protect the customer, not just the balance.',
    body: 'Fraud alerts catch some of it — after it starts. Spry trains the customer themselves to stop the scam before money leaves, co-branded to your bank. Reduce losses, keep deposits, and earn loyalty across generations.',
  },
];

const rotatorItems = [
  'financial advisors',
  'credit unions',
  'home care',
  'wealth advisors',
  'senior living',
  'community banks',
];
const partnerMail = 'mailto:hello@sawtoothtechnologies.com?subject=Spry%20partner%20call';
---

<Base
  title="Spry for Advisors, Credit Unions, Home Care, Senior Living & Banks"
  description="One provable scam-resilience program for the organizations families trust — financial and wealth advisors, credit unions, community banks, home-care agencies, and senior-living communities. Co-branded monthly Resilience Report, nothing for staff to run, never touches accounts. Founding-partner pilots open."
>
  <!-- ============ HERO (rotating audience) ============ -->
  <section class="section soln-hero">
    <div class="wrap center">
      <p class="kicker">For organizations</p>
      <h1 class="soln-hero__title">
        <span aria-hidden="true">
          Spry for
          <span class="rotator">
            <span class="rotator__list" id="rotator-list">
              <span class="rotator__item">{rotatorItems[rotatorItems.length - 1]}</span>
              {rotatorItems.map((item, i) => <span class={`rotator__item${i === 0 ? ' is-active' : ''}`}>{item}</span>)}
              <span class="rotator__item">{rotatorItems[0]}</span>
              <span class="rotator__item">{rotatorItems[1]}</span>
            </span>
          </span>
        </span>
        <span class="sr-only">Spry for financial advisors, credit unions, home care, wealth advisors, senior living, and community banks.</span>
      </h1>
      <p class="lede" style="margin-inline: auto;">
        If you serve older adults, Spry gives you a <em>provable</em> answer to the question every
        family is quietly asking: will you keep the person I love safe?
      </p>
      <div class="btn-row" style="justify-content: center; margin-top: 30px;">
        <a class="btn btn--primary" href={partnerMail}>Book a 20-minute call</a>
        <a class="btn btn--ghost" href="#pricing">See partner pricing</a>
      </div>
    </div>
  </section>

  <!-- ============ HOW PARTNERSHIPS WORK ============ -->
  <section class="section section--paper">
    <div class="wrap">
      <p class="kicker">How partnerships work</p>
      <h2 style="max-width: 34rem;">One program, built to run itself</h2>
      <div class="grid grid--2" style="margin-top: 36px;">
        <div class="card">
          <h3>Folds into your intake</h3>
          <p>Enrollment and consent ride along with your existing move-in, membership, or onboarding flow. We screen for cognitive fit with you — cognitively-appropriate participants only.</p>
        </div>
        <div class="card">
          <h3>Nothing for your staff to run</h3>
          <p>Email-first drills, in-the-moment coaching, and briefings on the newest scams are all handled by Spry. Your team is never in the alert loop.</p>
        </div>
        <div class="card">
          <h3>A co-branded monthly touchpoint</h3>
          <p>The Resilience Report reaches the family members your people choose — with your name on the good news. A recurring bridge to the next generation.</p>
        </div>
        <div class="card">
          <h3>Clean on compliance</h3>
          <p>Spry never touches money, accounts, or core systems — no integrations, no data feeds. That keeps vendor review and the compliance conversation short.</p>
        </div>
      </div>
      <p class="lede" style="margin-top: 28px; max-width: 44rem;">
        Plus an aggregate, anonymized stat you can put in a brochure or newsletter:
        <em>“our members caught 87% of simulated scams this quarter.”</em>
      </p>
    </div>
  </section>

  <!-- ============ AUDIENCE GRID ============ -->
  <section class="section">
    <div class="wrap">
      <p class="kicker">Who it's for</p>
      <h2 style="max-width: 34rem;">Built for the people families already trust</h2>
      <div class="grid grid--3" style="margin-top: 36px;">
        {audiences.map((a) => (
          <div class="card aud-card" id={a.id}>
            <h3>{a.name}</h3>
            <p class="aud-card__hook">{a.hook}</p>
            <p>{a.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ ROI ============ -->
  <section class="section section--paper">
    <div class="wrap prose">
      <h2>The math is almost unfair</h2>
      <p>
        The average reported senior-fraud loss is about $39,000, and more than 12,400 people lost
        $100,000 or more each in 2025. Preventing a <em>single</em> loss pays for years of the
        program. And unlike another amenity, a rate-table tweak, or a monitoring tool that only
        speaks up after the money moves, Spry comes with a monthly artifact families actually
        read — and a number you can market.
      </p>
    </div>
  </section>

  <!-- ============ PARTNER PRICING ============ -->
  <section class="section" id="pricing">
    <div class="wrap center">
      <p class="kicker">Partner pricing</p>
      <h2>Simple, volume-based, and it pays for itself</h2>
      <div style="margin-top: 32px;">
        <OrgPricing />
      </div>
    </div>
  </section>

  <CtaBand
    headline="Become a founding partner."
    body="A 20-minute call is enough to see whether Spry fits your community, agency, practice, or institution — and how a pilot works."
    cta="Book a 20-minute call"
    href={partnerMail}
  />
</Base>

<style>
  .soln-hero { padding-bottom: 64px; }
  .soln-hero__title {
    font-size: clamp(2rem, 4.4vw, 3rem);
    max-width: 34rem;
    margin-inline: auto;
  }
  .rotator {
    display: block;
    height: 3.75em; /* 3 lines of 1.25em — shows previous / active / next */
    overflow: hidden;
    padding: 0 0.15em;
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, #000 32%, #000 68%, transparent 100%);
            mask-image: linear-gradient(to bottom, transparent 0%, #000 32%, #000 68%, transparent 100%);
  }
  .rotator__list {
    display: flex;
    flex-direction: column;
    will-change: transform;
  }
  .rotator__item {
    height: 1.25em;
    line-height: 1.25;
    color: var(--pine-soft);
    opacity: 0.28;
    white-space: nowrap;
    transition: opacity 0.5s ease, color 0.5s ease;
  }
  .rotator__item.is-active { color: var(--amber-deep); opacity: 1; }

  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .aud-card { scroll-margin-top: 96px; }
  .aud-card__hook {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--pine);
    margin-bottom: 0.5em;
  }
  .aud-card p:last-child { margin-bottom: 0; font-size: 1rem; color: var(--ink-soft); }

  /* Partner pricing card (mirrors the Pricing page business tier) */
  .pricing-grid--single { max-width: 620px; margin-inline: auto; }
  .price-card {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 38px 32px;
    box-shadow: var(--shadow);
  }
  .price-card__price { font-size: 1.15rem; color: var(--ink-soft); margin-bottom: 2px; }
  .price-card__num {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 700;
    color: var(--pine-deep);
  }
  .price-card__alt { color: var(--ink-soft); font-size: 1rem; margin-bottom: 4px; }
  .price-card ul { padding-left: 1.2em; margin: 16px 0 20px; }
  .price-card ul li { margin-bottom: 0.55em; font-size: 1rem; }
  .price-card__note { font-size: 0.95rem; color: var(--ink-soft); margin-bottom: 24px; }
  .price-card .btn { width: 100%; }
</style>

<script>
  // Vertical audience rotator. Progressive + reduced-motion safe: without JS (or with
  // reduced-motion) the viewport simply shows the first audience, statically.
  const list = document.getElementById('rotator-list');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (list && !reduce) {
    // DOM order: [clone(last), real0..realN-1, clone(first), clone(second)].
    // A 3-line window shows the previous, active, and next audience.
    const items = Array.from(list.children);
    const N = items.length - 3;
    const lineH = 1.25; // em — must match .rotator__item height
    if (N > 1) {
      let a = 0;
      const setActive = (idx) => items.forEach((el, i) => el.classList.toggle('is-active', i === idx));
      const render = (animate) => {
        list.style.transition = animate ? 'transform 0.62s cubic-bezier(0.22, 0.61, 0.36, 1)' : 'none';
        list.style.transform = `translateY(-${a * lineH}em)`;
        setActive(a + 1); // active line is the middle of the window
      };
      render(false);
      window.setInterval(() => {
        a += 1;
        render(true);
        if (a === N) {
          // Now showing the clone of the first audience — snap back seamlessly.
          window.setTimeout(() => { a = 0; render(false); }, 640);
        }
      }, 2400);
    }
  }
</script>

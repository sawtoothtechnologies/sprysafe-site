---
import Base from '../layouts/Base.astro';
import ReportCard from '../components/ReportCard.astro';
import PhoneDemo from '../components/PhoneDemo.astro';
import CtaBand from '../components/CtaBand.astro';
import Faq from '../components/Faq.astro';
import { homeFaqs } from '../data/faqs.js';
---

<Base
  title="Spry — Simulated Scam Drills & Coaching, with a Monthly Resilience Report"
  description="A pamphlet won't stop the next scam. Practice will. Spry trains the person you care about with safe, simulated scam drills, coaching the moment they slip, and a drip of up-to-date scam briefings — plus a monthly Resilience Report. Consent-first."
>
  <!-- ============ HERO ============ -->
  <section class="section hero">
    <div class="wrap hero__grid">
      <div>
        <h1>Simulated scam drills for those most targeted.</h1>
        <p class="hero__metaphor">A pamphlet won't stop the next scam. Practice will.</p>
        <p class="lede">
          Empower someone you care about to practice the scam before it's real, with gentle
          coaching in the moment and a monthly Resilience Report for the family.
        </p>
        <div class="btn-row" style="margin-top: 30px;">
          <a class="btn btn--primary" href="/early-access">Get early access</a>
          <a class="btn btn--ghost" href="#how">See how it works</a>
        </div>
        <p class="trust-line">
          Consent-first. No bank access. Nothing for them to install. Cancel anytime —
          with a 60-day money-back guarantee.
        </p>
      </div>
      <div class="hero__card">
        <ReportCard />
      </div>
    </div>
  </section>

  <!-- ============ THE PROBLEM ============ -->
  <section class="section section--paper">
    <div class="wrap">
      <p class="kicker">Why now</p>
      <h2 style="max-width: 34rem;">Scams are getting smarter, and losses are exploding</h2>
      <p class="lede">
        AI voice clones and deepfakes have made fraud dramatically more convincing.
      </p>

      <div class="stats-band" id="stats-band">
        <!-- 7 in 10 — daily contact donut -->
        <div class="stats-card stats-donut" role="img" aria-label="71 percent of adults 60 and older are contacted daily by scammers">
          <div class="donut" aria-hidden="true">
            <svg viewBox="0 0 120 120">
              <circle class="donut__track" cx="60" cy="60" r="52" />
              <circle class="donut__arc" cx="60" cy="60" r="52" />
            </svg>
            <span class="donut__center">71%</span>
          </div>
          <p class="stats-donut__text" aria-hidden="true">of adults 60+ contacted daily by scammers</p>
        </div>

        <!-- $38,000 — average loss -->
        <div class="stats-card stats-loss">
          <span class="stats-loss__num" data-countup data-prefix="$" data-target="38000">$38,000</span>
          <p class="stats-loss__label">average reported loss</p>
        </div>

        <!-- Losses rising — one line, one number -->
        <div class="stats-card stats-rise" role="img" aria-label="Reported losses rose 59 percent last year">
          <span class="stats-rise__num">+59%</span>
          <p class="stats-rise__label">reported losses, last year</p>
          <svg class="stats-rise__chart" viewBox="0 0 300 80" preserveAspectRatio="none" aria-hidden="true">
            <path class="rise-line" d="M4,74 C80,70 148,58 204,38 S 282,10 296,6" fill="none" vector-effect="non-scaling-stroke" />
          </svg>
        </div>
      </div>

      <p class="lede" style="margin-top: 36px; max-width: 44rem;">
        The good news: spotting a scam is a trainable skill. Classes and pamphlets fade, but
        practice sticks. That's where Spry comes in.
      </p>
    </div>
  </section>

  <!-- ============ HOW IT WORKS ============ -->
  <section class="section" id="how">
    <div class="wrap">
      <p class="kicker">How it works</p>
      <h2>Education, simulation, peace of mind</h2>
      <p class="lede">Four simple parts, each with one job: build the instinct that spots a scam before it costs anything.</p>

      <div class="hiw" id="hiw">
        <div class="hiw__cards">
          <button class="hiw__card is-active" aria-expanded="true">
            <span class="hiw__card-num">1</span>
            <span class="hiw__card-body">
              <span class="hiw__card-title">Enroll in 2 minutes</span>
              <span class="hiw__card-teaser"><span>Tell us about the person you're signing up. They opt in personally, and there's nothing for them to install or manage.</span></span>
            </span>
            <span class="hiw__progress" aria-hidden="true"><span></span></span>
          </button>
          <button class="hiw__card" aria-expanded="false">
            <span class="hiw__card-num">2</span>
            <span class="hiw__card-body">
              <span class="hiw__card-title">Safe, simulated drills</span>
              <span class="hiw__card-teaser"><span>Practice versions of current scams arrive unannounced. A slip becomes a friendly 30-second coaching moment. No lecture, no shame.</span></span>
            </span>
            <span class="hiw__progress" aria-hidden="true"><span></span></span>
          </button>
          <button class="hiw__card" aria-expanded="false">
            <span class="hiw__card-num">3</span>
            <span class="hiw__card-body">
              <span class="hiw__card-title">A quiet drip of education</span>
              <span class="hiw__card-teaser"><span>Two-minute briefings on the newest scams, spaced out so the knowledge stays fresh instead of fading.</span></span>
            </span>
            <span class="hiw__progress" aria-hidden="true"><span></span></span>
          </button>
          <button class="hiw__card" aria-expanded="false">
            <span class="hiw__card-num">4</span>
            <span class="hiw__card-body">
              <span class="hiw__card-title">Monthly Resilience Report</span>
              <span class="hiw__card-teaser"><span>One page a month: what we ran, what they caught, and how their instincts are trending.</span></span>
            </span>
            <span class="hiw__progress" aria-hidden="true"><span></span></span>
          </button>
        </div>

        <div class="hiw__phone">
          <PhoneDemo />
        </div>
      </div>

      <p style="margin-top: 40px;"><a class="btn btn--ghost" href="/how-it-works">See a drill up close →</a></p>
    </div>
  </section>

  <!-- ============ RESILIENCE REPORT SHOWCASE ============ -->
  <section class="section section--pine">
    <div class="wrap hero__grid">
      <div>
        <p class="kicker">The Resilience Report</p>
        <h2>Peace of mind you can actually read</h2>
        <p class="lede">
          Monitoring apps only message you when something bad might have happened. Spry sends
          you proof of something good: the person you care about is getting harder to fool, month
          after month. It's one page. It takes two minutes to read. And it turns “I hope they're
          okay” into “I know they're ready.”
        </p>
      </div>
      <div class="hero__card">
        <ReportCard />
      </div>
    </div>
  </section>

  <!-- ============ COMPARISON ============ -->
  <section class="section">
    <div class="wrap">
      <h2 style="max-width: 36rem;">Everything else waits for the scam. We get there first.</h2>
      <div class="table-scroll" style="margin-top: 36px;">
        <table class="compare">
          <thead>
            <tr>
              <th scope="col">Approach</th>
              <th scope="col">What it does</th>
              <th scope="col">The gap</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="compare__who">Account monitoring</td>
              <td>Watches the bank account, alerts family to suspicious transactions</td>
              <td>Alerts arrive <em>after</em> the money moves — and quietly signal “we're watching you”</td>
            </tr>
            <tr>
              <td class="compare__who">Call &amp; text blockers</td>
              <td>Filter known scam numbers</td>
              <td>The day one slips through — and one always does — the person is untrained</td>
            </tr>
            <tr>
              <td class="compare__who">Free classes &amp; pamphlets</td>
              <td>Teach scam awareness once</td>
              <td>The benefit fades within about a month — and the content goes stale as new scams appear</td>
            </tr>
            <tr class="compare__hero">
              <td class="compare__who">Spry</td>
              <td>Trains the person with safe practice and coaching, keeps their knowledge current with drip briefings, and measures progress monthly</td>
              <td>The person becomes the defense — without giving up an ounce of independence</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="lede" style="margin-top: 28px;">Blockers and monitors are fine seatbelts. Spry is the driving lesson.</p>
    </div>
  </section>

  <!-- ============ RESEARCH STRIP ============ -->
  <section class="section section--paper">
    <div class="wrap center">
      <p class="kicker">The evidence</p>
      <h2 style="max-width: 40rem; margin-inline: auto;">Built on what actually works</h2>
      <p class="lede" style="max-width: 48rem; margin-inline: auto;">
        A 2024 federal review of scam-prevention research found one-time education fades within
        weeks — and called messaging that <em>simulates</em> being scammed “promising.” A
        University of Florida study found performance on safe practice tests predicts real-world
        risk. It's the same simulate-coach-measure loop Fortune 500 companies have trusted for
        years — simply never pointed at the people who need it most.
      </p>
      <p class="footnote" style="margin-top: 20px; max-width: 48rem; margin-inline: auto;">
        Sources:
        <a href="https://consumer.ftc.gov/system/files/consumer_ftc_gov/pdf/A%20Review%20of%20Scam%20Prevention%20Messaging%20Research.pdf">FTC scam-prevention messaging review (2024)</a> ·
        <a href="https://academic.oup.com/pnasnexus/article/3/8/pgae296/7725152">University of Florida phishing study, PNAS Nexus (2024)</a> ·
        <a href="/why-it-works">read the full case →</a>
      </p>
    </div>
  </section>

  <!-- ============ FOR ORGANIZATIONS ============ -->
  <section class="section">
    <div class="wrap">
      <p class="kicker">For organizations</p>
      <h2>Also built for the people families trust</h2>
      <div class="grid grid--2" style="margin-top: 36px;">
        <div class="card">
          <h3>Senior-living communities</h3>
          <p>
            Give tours a differentiator no one else in town can claim: <em>we actively train
            residents against scams — and prove it to families every month.</em>
          </p>
          <p><a class="cta-link" href="/solutions#senior-living">Learn more →</a></p>
        </div>
        <div class="card">
          <h3>Home-care agencies</h3>
          <p>A safety add-on your clients' families will thank you for — and a new recurring revenue line.</p>
          <p><a class="cta-link" href="/solutions#home-care">Learn more →</a></p>
        </div>
        <div class="card">
          <h3>Financial &amp; wealth advisors</h3>
          <p>One scammed client can erase years of trust and six figures of AUM. Protect the person, not just the portfolio.</p>
          <p><a class="cta-link" href="/solutions#financial-advisors">Learn more →</a></p>
        </div>
        <div class="card">
          <h3>Credit unions</h3>
          <p>A member benefit that keeps savings where they belong — and turns fraud prevention into loyalty across generations.</p>
          <p><a class="cta-link" href="/solutions#credit-unions">Learn more →</a></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ PROMISE STRIP ============ -->
  <section class="section--tight section">
    <div class="wrap">
      <div class="card" style="border-left: 6px solid var(--amber);">
        <p style="margin: 0; font-size: 1.1rem;">
          <strong>Consent-first, always.</strong> Every participant opts in personally. Drills are
          gentle, immediately debriefed, and designed with published research on older-adult
          learning. No shame, no tricks for tricks' sake, no surprises the family didn't sign up
          for. <a href="/promise">Read our full promise →</a>
        </p>
      </div>
    </div>
  </section>

  <!-- ============ FAQ TEASER ============ -->
  <section class="section">
    <div class="wrap" style="max-width: 800px;">
      <h2 class="center">Fair questions, honest answers</h2>
      <div style="margin-top: 32px;">
        <Faq items={homeFaqs} />
      </div>
      <p class="center" style="margin-top: 26px;"><a href="/faq">Read the full FAQ →</a></p>
    </div>
  </section>

  <!-- ============ FINAL CTA ============ -->
  <CtaBand />

  <!-- ============ SOURCES ============ -->
  <div class="wrap">
    <p class="footnote center" style="padding: 26px 0 34px; margin: 0;">
      Sources: <a href="https://apnorc.org/projects/fifty-eight-percent-of-adults-report-receiving-scam-attempts-daily/">AP-NORC Center poll (2026)</a> ·
      <a href="https://www.fbi.gov/news/stories/scammers-target-older-adult-victims">FBI, on the IC3 2025 Internet Crime Report</a>
    </p>
  </div>
</Base>

<script>
  // Count-up animation for the "Why now" stat tiles.
  // Progressive enhancement: markup ships the final numbers, so no-JS visitors
  // (and search engines) always see real values.
  const els = document.querySelectorAll('[data-countup]');
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const render = (el, value) => {
    const decimals = parseInt(el.dataset.decimals || '0', 10);
    const num = decimals
      ? value.toFixed(decimals)
      : Math.round(value).toLocaleString('en-US');
    el.textContent = (el.dataset.prefix || '') + num + (el.dataset.suffix || '');
  };

  const animate = (el) => {
    const target = parseFloat(el.dataset.target || '0');
    if (reduceMotion) { render(el, target); return; }
    const duration = 1400;
    let startTime;
    const tick = (now) => {
      if (startTime === undefined) startTime = now;
      const progress = Math.min((now - startTime) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 3); // ease-out cubic
      render(el, target * eased);
      if (progress < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  };

  if (els.length && 'IntersectionObserver' in window && !reduceMotion) {
    els.forEach((el) => render(el, 0)); // zero out only once JS is confirmed running
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            animate(entry.target);
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.4 }
    );
    els.forEach((el) => io.observe(el));
  }

  // Stats band — arm the pictograph, bars, and badges, then play the whole
  // band once it scrolls into view. Markup ships the final state, so no-JS
  // and reduced-motion visitors see everything without animation.
  const band = document.getElementById('stats-band');
  if (band && 'IntersectionObserver' in window && !reduceMotion) {
    band.classList.add('stats--anim');
    const bandIo = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            band.classList.add('stats--play');
            bandIo.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.25 }
    );
    bandIo.observe(band);
  }

  // "How it works" — an expanding step carousel synced with the phone demo.
  // The active card expands to show its teaser; autoplay lingers on each step,
  // then moves on (the drill step gets extra time so the phone sequence can
  // finish). Autoplay only starts once the section scrolls into view, so
  // visitors always see it from step 1. Hovering pauses; clicking a card takes
  // over. Without JS, all four cards render expanded.
  const hiw = document.getElementById('hiw');
  if (hiw) {
    hiw.classList.add('hiw--js');
    const cards = Array.from(hiw.querySelectorAll('.hiw__card'));
    const bars = Array.from(hiw.querySelectorAll('.hiw__progress > span'));
    const n = cards.length;
    const DURATIONS = [3500, 6000, 4000, 4000];
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let current = 0, elapsed = 0, last = null, hovering = false, stopped = false, raf = 0;

    const setProgress = (frac) =>
      bars.forEach((b, j) => { b.style.transform = 'scaleX(' + (j === current ? frac : 0) + ')'; });

    const show = (i) => {
      current = (i + n) % n;
      cards.forEach((card, j) => {
        const active = j === current;
        card.classList.toggle('is-active', active);
        card.setAttribute('aria-expanded', active ? 'true' : 'false');
      });
      elapsed = 0;
      setProgress(0);
      // Tell the phone demo which scene to play.
      document.dispatchEvent(new CustomEvent('spry:hiwchange', { detail: { index: current } }));
    };

    const stop = () => {
      stopped = true;
      if (raf) cancelAnimationFrame(raf);
      setProgress(0);
    };

    cards.forEach((card, j) => {
      card.addEventListener('click', () => { show(j); stop(); });
    });
    hiw.addEventListener('mouseenter', () => { hovering = true; });
    hiw.addEventListener('mouseleave', () => { hovering = false; });

    show(0);

    if (!reduce && 'IntersectionObserver' in window) {
      const frame = (now) => {
        if (last === null) last = now;
        const dt = now - last;
        last = now;
        if (!hovering && !stopped) {
          elapsed += dt;
          const duration = DURATIONS[current] || 4000;
          setProgress(Math.min(elapsed / duration, 1));
          if (elapsed >= duration) show((current + 1) % n);
        }
        raf = requestAnimationFrame(frame);
      };
      const hiwIo = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              raf = requestAnimationFrame(frame);
              hiwIo.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.3 }
      );
      hiwIo.observe(hiw);
    }
  }
</script>

<style>
  .hero { padding-top: 72px; }
  .hero__metaphor {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--pine);
    line-height: 1.3;
    margin: 0 0 18px;
  }
  .hero__grid {
    display: grid;
    gap: 56px;
    align-items: center;
  }
  @media (min-width: 920px) {
    .hero__grid { grid-template-columns: 1.15fr 1fr; }
  }
  .hero__card { display: flex; justify-content: center; }
  @media (min-width: 920px) {
    .hero__card { transform: rotate(1.5deg); }
  }

  /* ---------- Stats band: three equal columns ---------- */
  .stats-band { display: grid; gap: 18px; margin-top: 40px; }
  .stats-band > * { min-width: 0; }
  @media (min-width: 880px) {
    .stats-band { grid-template-columns: repeat(3, 1fr); align-items: stretch; }
  }
  .stats-card {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 28px;
  }

  /* 7 in 10 — daily contact donut */
  .stats-donut {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }
  .donut { position: relative; width: 150px; }
  .donut svg { display: block; width: 100%; }
  .donut__track { fill: none; stroke: var(--line); stroke-width: 11; }
  .donut__arc {
    fill: none;
    stroke: var(--pine);
    stroke-width: 11;
    stroke-linecap: round;
    stroke-dasharray: 326.7;
    stroke-dashoffset: 94.8; /* 71% of the ring */
    transform: rotate(-90deg);
    transform-origin: center;
  }
  .stats--anim .donut__arc { stroke-dashoffset: 326.7; }
  .stats--play .donut__arc {
    animation: donutSweep 1.1s cubic-bezier(0.22, 0.61, 0.36, 1) 0.2s forwards;
  }
  @keyframes donutSweep { to { stroke-dashoffset: 94.8; } }
  .donut__center {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 2.2rem;
    letter-spacing: -0.02em;
    color: var(--pine-deep);
  }
  .stats--anim .donut__center { opacity: 0; }
  .stats--play .donut__center { animation: statFade 0.5s ease 0.8s forwards; }
  .stats-donut__text {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 15rem;
  }
  .stats--anim .stats-donut__text { opacity: 0; }
  .stats--play .stats-donut__text { animation: statFade 0.5s ease 0.9s forwards; }
  @keyframes statFade { to { opacity: 1; } }

  /* $38,000 — inverted card */
  .stats-loss {
    background: var(--pine-deep);
    border-color: var(--pine-deep);
    color: var(--sage-pale);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .stats-loss__num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.4rem, 4.4vw, 3.2rem);
    color: var(--cream);
    letter-spacing: -0.02em;
    line-height: 1.05;
    display: block;
    margin-bottom: 10px;
  }
  .stats-loss__label { margin: 0; font-size: 1.02rem; line-height: 1.5; max-width: 24rem; }

  /* Losses rising — one line, one number */
  .stats-rise {
    display: flex;
    flex-direction: column;
    padding-bottom: 0;
    overflow: hidden;
    min-height: 200px;
  }
  .stats-rise__num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.4rem, 4.4vw, 3.2rem);
    color: var(--pine-deep);
    letter-spacing: -0.02em;
    line-height: 1.05;
    display: block;
    margin-bottom: 10px;
  }
  .stats-rise__label {
    margin: 0;
    font-size: 1.02rem;
    line-height: 1.5;
    color: var(--ink-soft);
  }
  .stats-rise__chart {
    margin-top: auto;
    display: block;
    width: 100%;
    height: 96px;
  }
  .rise-line {
    stroke: var(--pine);
    stroke-width: 3.5;
    stroke-linecap: round;
  }
  .stats--anim .rise-line {
    stroke-dasharray: 420;
    stroke-dashoffset: 420;
  }
  .stats--play .rise-line {
    animation: riseDraw 1.2s ease-out 0.5s forwards;
  }
  @keyframes riseDraw { to { stroke-dashoffset: 0; } }

  /* ---------- How-it-works — expanding step carousel ---------- */
  .hiw {
    margin-top: 44px;
    display: grid;
    gap: 44px;
  }
  @media (min-width: 1040px) {
    /* Steps on the left, live phone demo on the right. */
    .hiw { grid-template-columns: minmax(0, 1fr) 340px; align-items: center; }
  }
  .hiw__phone { display: flex; justify-content: center; }
  .hiw__cards { display: grid; gap: 12px; }
  .hiw__card {
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: 38px 1fr;
    column-gap: 16px;
    align-items: start;
    text-align: left;
    font-family: var(--font-body);
    background: var(--white);
    border: 1.5px solid var(--line);
    border-radius: var(--radius);
    padding: 18px 22px 20px;
    cursor: pointer;
    box-shadow: var(--shadow);
    transition: border-color 0.25s ease, background 0.35s ease;
  }
  .hiw__card:hover { border-color: var(--pine-soft); }
  .hiw__card:focus-visible { outline: 3px solid var(--amber); outline-offset: 2px; }
  .hiw__card.is-active { background: var(--pine-deep); border-color: var(--pine-deep); }
  .hiw__card-num {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: var(--pine);
    color: var(--cream);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    display: grid;
    place-items: center;
    transition: background 0.25s ease, color 0.25s ease;
  }
  .hiw__card.is-active .hiw__card-num { background: var(--amber); color: var(--pine-deep); }
  .hiw__card-body { display: block; min-width: 0; }
  .hiw__card-title {
    display: block;
    font-family: var(--font-display);

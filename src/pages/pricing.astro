---
import Base from '../layouts/Base.astro';
import CtaBand from '../components/CtaBand.astro';
import OrgPricing from '../components/OrgPricing.astro';
import { checkoutLinks } from '../data/checkout.js';

// Checkout URL for a plan + billing period, falling back to the waitlist
// until the Stripe Payment Links are pasted into src/data/checkout.js.
const co = (plan, mode) => checkoutLinks[plan]?.[mode] || '/early-access';
---

<Base
  title="Spry Pricing — Plans from $9/month, with a 14-Day Free Trial"
  description="Three simple plans: one person ($9/mo), up to two ($15/mo), or up to four ($19/mo), billed annually — each with a 14-day free trial and a 60-day money-back guarantee. Business pricing for communities, agencies, and advisors."
>
  <!-- ============ FOR FAMILIES ============ -->
  <section class="section pricing" id="family-plans">
    <div class="wrap center pricing__head">
      <p class="kicker">For families</p>
      <h1 class="pricing__title">Simple, transparent pricing</h1>
      <div class="billing-toggle-row">
        <div class="billing-toggle" role="group" aria-label="Billing period">
          <button class="billing-toggle__btn is-active" data-billing="annual" aria-pressed="true">Annual</button>
          <button class="billing-toggle__btn" data-billing="monthly" aria-pressed="false">Monthly</button>
        </div>
      </div>
      <p class="billing-note is-on" aria-live="polite">3 months free, every year</p>
      <p class="org-jump">Buying for a community, practice, or team? <a href="#org-pricing">Organization pricing is below</a>.</p>
    </div>

    <div class="wrap">
      <div class="pricing-grid pricing-grid--family">
        <!-- Tier 1 — one person -->
        <div class="price-card">
          <p class="price-card__label">One person</p>
          <h2>Individual</h2>
          <p class="price-card__price">
            <span class="price-card__num" data-annual="$9" data-monthly="$12">$9</span>/month
          </p>
          <p class="price-card__billing" data-annual="$108 a year, billed annually" data-monthly="billed monthly, cancel anytime">$108 a year, billed annually</p>
          <ul>
            <li>4–6 safe, realistic drills a month, modeled on current scams</li>
            <li>Gentle 30-second coaching the moment a drill lands</li>
            <li>Monthly Resilience Report, with trend line and briefings, shared with up to 4 family members</li>
          </ul>
          <a class="btn btn--ghost" data-checkout href={co('individual', 'annual')} data-annual-href={co('individual', 'annual')} data-monthly-href={co('individual', 'monthly')}>Start free trial</a>
          <p class="price-card__trial">Includes 14-day free trial</p>
        </div>

        <!-- Tier 2 — up to two (MOST POPULAR) -->
        <div class="price-card price-card--featured">
          <span class="price-badge">Most popular</span>
          <p class="price-card__label">Up to two people</p>
          <h2>Couples &amp; pairs</h2>
          <p class="price-card__price">
            <span class="price-card__num" data-annual="$15" data-monthly="$20">$15</span>/month
          </p>
          <p class="price-card__billing" data-annual="$180 a year, billed annually" data-monthly="billed monthly, cancel anytime">$180 a year, billed annually</p>
          <p class="price-card__inherit">Everything in <strong>Individual</strong>, plus:</p>
          <ul>
            <li>Covers up to <strong>two</strong> people, each with their own drills, coaching, and Resilience Report</li>
            <li>Ideal for both parents, or you and someone you love</li>
            <li>One subscription, one bill, about <span data-annual="$7.50" data-monthly="$10">$7.50</span> per person</li>
          </ul>
          <a class="btn btn--primary" data-checkout href={co('couples', 'annual')} data-annual-href={co('couples', 'annual')} data-monthly-href={co('couples', 'monthly')}>Start free trial</a>
          <p class="price-card__trial">Includes 14-day free trial</p>
        </div>

        <!-- Tier 3 — up to four -->
        <div class="price-card">
          <p class="price-card__label">Up to four people</p>
          <h2>Family</h2>
          <p class="price-card__price">
            <span class="price-card__num" data-annual="$19" data-monthly="$25">$19</span>/month
          </p>
          <p class="price-card__billing" data-annual="$228 a year, billed annually" data-monthly="billed monthly, cancel anytime">$228 a year, billed annually</p>
          <p class="price-card__inherit">Everything in <strong>Couples &amp; pairs</strong>, plus:</p>
          <ul>
            <li>Covers up to <strong>four</strong> people, each with their own drills, coaching, and Resilience Report</li>
            <li>Room for both parents plus an aunt, uncle, or in-law</li>
            <li>Add or swap enrolled people anytime</li>
            <li>The best per-person value, about <span data-annual="$4.75" data-monthly="$6.25">$4.75</span> per person</li>
          </ul>
          <a class="btn btn--ghost" data-checkout href={co('family', 'annual')} data-annual-href={co('family', 'annual')} data-monthly-href={co('family', 'monthly')}>Start free trial</a>
          <p class="price-card__trial">Includes 14-day free trial</p>
        </div>
      </div>
      <p class="guarantee center">
        Every plan comes with a <strong>60-day money-back guarantee</strong> — if Spry isn't a
        fit, we refund in full. No questions, no forms.
      </p>
      <p class="plan-fineprint center">
        All plans: nothing to install, cancel anytime. Email drills today; text drills with
        written consent; practice calls coming soon.
      </p>
    </div>
  </section>

  <!-- ============ FOR ORGANIZATIONS ============ -->
  <section class="section--tight section section--paper" id="org-pricing">
    <div class="wrap center">
      <p class="kicker">For organizations</p>
      <h2>Communities, agencies, advisors &amp; institutions</h2>
      <div style="margin-top: 32px;">
        <OrgPricing />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap" style="max-width: 800px;">
      <h2 class="center">Pricing questions</h2>
      <div style="margin-top: 30px;">
        <details class="faq-item">
          <summary>Which plan should I choose?</summary>
          <div class="faq-body">
            <p>
              Most families pick <strong>Couples &amp; pairs</strong> — it covers both parents (or
              a couple) on one bill and is our most popular plan. Choose Individual for one person,
              or Family if you're protecting up to four people, like both parents plus an aunt or
              in-law. You can move up a plan anytime.
            </p>
          </div>
        </details>
        <details class="faq-item">
          <summary>Why does this cost more than a call blocker?</summary>
          <div class="faq-body">
            <p>
              A blocker filters some scams. Spry changes what happens when one gets through —
              and one always gets through. You're not buying software; you're buying a skill and
              monthly proof it's growing.
            </p>
          </div>
        </details>
        <details class="faq-item">
          <summary>How does the free trial work?</summary>
          <div class="faq-body">
            <p>
              Every plan starts with a 14-day free trial — long enough to see the first drills and
              coaching in action. And after that, you're still covered by the 60-day money-back
              guarantee.
            </p>
          </div>
        </details>
        <details class="faq-item">
          <summary>What if my parent doesn't want it?</summary>
          <div class="faq-body">
            <p>
              Then we don't enroll them. Consent isn't a checkbox for us; it's the product working
              as designed. Many parents warm up after seeing a sample drill — most people enjoy
              being good at this.
            </p>
          </div>
        </details>
        <details class="faq-item">
          <summary>Contracts?</summary>
          <div class="faq-body">
            <p>None. Monthly plans cancel anytime; annual plans refund unused months.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <CtaBand />
</Base>

<script>
  // Billing-period toggle (annual ↔ monthly). Swaps the price, billing note, and savings line
  // on every family card. Progressive enhancement: without JS the toggle is hidden and the
  // cards ship annual pricing (with the monthly figure available on request).
  const fam = document.getElementById('family-plans');
  if (fam) {
    const billing = fam.querySelector('.billing-toggle');
    if (billing) {
      fam.classList.add('billing--js');
      const bBtns = Array.from(billing.querySelectorAll('.billing-toggle__btn'));
      const swappable = Array.from(fam.querySelectorAll('[data-annual]'));
      const note = fam.querySelector('.billing-note');
      const apply = (mode) => {
        swappable.forEach((el) => {
          el.textContent = el.getAttribute('data-' + mode) || '';
        });
        bBtns.forEach((b) => {
          const active = b.dataset.billing === mode;
          b.classList.toggle('is-active', active);
          b.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
        // "3 months free" pops in under the pill on annual, hides on monthly.
        if (note) note.classList.toggle('is-on', mode === 'annual');
        // Point each checkout button at the matching Stripe link.
        fam.querySelectorAll('[data-checkout]').forEach((a) => {
          const href = a.getAttribute('data-' + mode + '-href');
          if (href) a.setAttribute('href', href);
        });
      };
      bBtns.forEach((b) => b.addEventListener('click', () => apply(b.dataset.billing)));
      apply('annual');
    }
  }
</script>

<style>
  /* Compact header sits in the same section as the cards, so there's no big gap. */
  .pricing__head { margin-bottom: 40px; }
  .pricing__title {
    font-size: clamp(1.7rem, 3.2vw, 2.3rem);
    max-width: 34rem;
    margin: 0 auto 24px;
  }
  /* Quiet FYI, not a call to action. */
  .org-jump { margin: 18px 0 0; font-size: 0.85rem; color: var(--ink-soft); }
  .org-jump a {
    font-weight: 500;
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-style: dotted;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
  }
  .org-jump a:hover { color: var(--pine-deep); text-decoration-style: solid; }

  /* ---------- Billing-period toggle ---------- */
  .billing-toggle-row { display: flex; justify-content: center; }
  .billing-toggle {
    display: none;
    background: var(--paper);
    border: 1.5px solid var(--line);
    border-radius: 999px;
    padding: 5px;
    gap: 4px;
  }
  .billing--js .billing-toggle { display: inline-flex; }
  .billing-toggle__btn {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--ink-soft);
    background: transparent;
    border: none;
    border-radius: 999px;
    padding: 9px 20px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.12s ease, color 0.12s ease;
  }
  .billing-toggle__btn:hover { color: var(--pine-deep); }
  .billing-toggle__btn:focus-visible { outline: 3px solid var(--amber); outline-offset: 2px; }
  .billing-toggle__btn.is-active { background: var(--pine-deep); color: var(--cream); }
  /* Savings note under the pill — pops in on Annual, hides on Monthly. */
  .billing-note {
    margin: 12px 0 0;
    min-height: 1.4em;
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--amber-deep);
    opacity: 0;
    transform: translateY(-4px) scale(0.95);
    transition: opacity 0.25s ease, transform 0.3s cubic-bezier(0.34, 1.4, 0.64, 1);
  }
  .billing-note.is-on { opacity: 1; transform: none; }

  /* ---------- Plan cards ---------- */
  .pricing-grid {
    display: grid;
    gap: 28px;
    align-items: start;
  }
  @media (min-width: 900px) {
    .pricing-grid--family { grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .pricing-grid--single { grid-template-columns: 1fr; max-width: 620px; margin-inline: auto; }
  }
  .price-card {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 38px 32px;
    box-shadow: var(--shadow);
  }
  .price-card--featured {
    border: 2px solid var(--pine);
    box-shadow: var(--shadow-lg);
    position: relative;
  }
  @media (min-width: 900px) {
    .price-card--featured { transform: translateY(-10px); }
  }
  .price-badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--amber);
    color: var(--pine-deep);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: 999px;
    white-space: nowrap;
    box-shadow: var(--shadow);
  }
  .price-card__label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber-deep);
    margin-bottom: 6px;
  }
  .price-card h2 { margin-bottom: 10px; }
  .price-card__price { font-size: 1.15rem; color: var(--ink-soft); margin-bottom: 2px; }
  .price-card__num {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 700;
    color: var(--pine-deep);
  }
  .price-card__billing {
    color: var(--ink-soft);
    font-size: 0.9rem;
    margin: 0 0 4px;
  }
  /* "Everything in X, plus:" — makes tier inheritance visually explicit. */
  .price-card__inherit {
    display: inline-block;
    background: #ebf2ed;
    color: var(--pine-deep);
    font-size: 0.88rem;
    font-weight: 600;
    border-radius: 999px;
    padding: 6px 14px;
    margin: 10px 0 14px;
  }
  .price-card__alt { color: var(--ink-soft); font-size: 1rem; }
  .price-card ul { padding-left: 1.2em; margin: 14px 0 20px; }
  .price-card ul li { margin-bottom: 0.55em; font-size: 1rem; }
  .price-card__note { font-size: 0.95rem; color: var(--ink-soft); margin-bottom: 24px; }
  .price-card__trial {
    font-size: 0.9rem;
    color: var(--ink-soft);
    margin: 10px 0 0;
  }
  .price-card .btn { width: 100%; }
  .guarantee {
    font-size: 0.95rem;
    color: var(--ink-soft);
    margin-top: 32px;
  }
  .guarantee strong { color: var(--pine-deep); }
  .plan-fineprint {
    font-size: 0.85rem;
    color: var(--ink-soft);
    margin-top: 8px;
  }
</style>

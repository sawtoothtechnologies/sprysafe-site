---
import Base from '../layouts/Base.astro';
import CtaBand from '../components/CtaBand.astro';
---

<Base
  title="Spry Pricing — Plans from $9/month, with a 14-Day Free Trial"
  description="Three simple plans: one person ($9/mo), up to two ($15/mo), or up to four ($19/mo), billed annually — each with a 14-day free trial and a 60-day money-back guarantee. Business pricing for communities, agencies, and advisors."
>
  <section class="section">
    <div class="wrap center">
      <p class="kicker">Pricing</p>
      <h1>Less than a streaming subscription. Somewhat higher stakes.</h1>
      <p class="lede" style="margin-inline: auto;">
        Every plan includes real, evolving drills — not a library of stale quizzes — plus
        in-the-moment coaching and the monthly Resilience Report.
      </p>
    </div>
  </section>

  <section class="section--tight section">
    <div class="wrap" id="plans">
      <div class="plans-toggle-row">
        <div class="plans-toggle" id="plan-toggle" role="group" aria-label="Choose plan type">
          <button class="plans-toggle__btn is-active" data-panel="family" aria-pressed="true">For individuals &amp; families</button>
          <button class="plans-toggle__btn" data-panel="business" aria-pressed="false">For businesses</button>
        </div>
      </div>

      <!-- ============ INDIVIDUALS & FAMILIES ============ -->
      <div class="plans-panel is-active" data-plan="family">
        <div class="billing-toggle-row">
          <div class="billing-toggle" role="group" aria-label="Billing period">
            <button class="billing-toggle__btn is-active" data-billing="annual" aria-pressed="true">
              Annual <span class="billing-toggle__save">3 months free</span>
            </button>
            <button class="billing-toggle__btn" data-billing="monthly" aria-pressed="false">Monthly</button>
          </div>
        </div>

        <div class="pricing-grid pricing-grid--family">
          <!-- Tier 1 — one person -->
          <div class="price-card">
            <p class="price-card__label">One person</p>
            <h2>Individual</h2>
            <p class="price-card__price">
              <span class="price-card__num" data-annual="$9" data-monthly="$12">$9</span>/month
            </p>
            <p class="price-card__billing" data-annual="$108 a year, billed annually" data-monthly="billed monthly, cancel anytime">$108 a year, billed annually</p>
            <p class="price-card__save" data-annual="3 months free vs. monthly billing" data-monthly="">3 months free vs. monthly billing</p>
            <ul>
              <li>4–6 safe, realistic drills a month, modeled on current scams</li>
              <li>Email drills now; text with written consent; practice calls coming soon</li>
              <li>Gentle 30-second coaching the moment a drill lands</li>
              <li>Monthly Resilience Report to up to 4 family members</li>
              <li>Resilience trend line and quiet early-warning flags</li>
              <li>Plain-English briefings on this month's newest scams</li>
              <li>Nothing to install · cancel anytime</li>
            </ul>
            <a class="btn btn--ghost" href="/early-access">Start free trial</a>
            <p class="price-card__trial">Includes 14-day free trial</p>
          </div>

          <!-- Tier 2 — up to two (MOST POPULAR) -->
          <div class="price-card price-card--featured">
            <span class="price-badge">Most popular</span>
            <p class="price-card__label">Up to two people</p>
            <h2>Couples &amp; pairs</h2>
            <p class="price-card__price">
              <span class="price-card__num" data-annual="$15" data-monthly="$20">$15</span>/month
            </p>
            <p class="price-card__billing" data-annual="$180 a year, billed annually" data-monthly="billed monthly, cancel anytime">$180 a year, billed annually</p>
            <p class="price-card__save" data-annual="3 months free vs. monthly billing" data-monthly="">3 months free vs. monthly billing</p>
            <ul>
              <li>Everything in Individual, for <strong>two</strong> enrolled people</li>
              <li>Each person gets their own drills, coaching, and Resilience Report</li>
              <li>Ideal for both parents — or you and someone you love</li>
              <li>One subscription, one bill — about $7.50 per person</li>
            </ul>
            <a class="btn btn--primary" href="/early-access">Start free trial</a>
            <p class="price-card__trial">Includes 14-day free trial</p>
          </div>

          <!-- Tier 3 — up to four -->
          <div class="price-card">
            <p class="price-card__label">Up to four people</p>
            <h2>Family</h2>
            <p class="price-card__price">
              <span class="price-card__num" data-annual="$19" data-monthly="$25">$19</span>/month
            </p>
            <p class="price-card__billing" data-annual="$228 a year, billed annually" data-monthly="billed monthly, cancel anytime">$228 a year, billed annually</p>
            <p class="price-card__save" data-annual="3 months free vs. monthly billing" data-monthly="">3 months free vs. monthly billing</p>
            <ul>
              <li>Everything in Couples, for up to <strong>four</strong> enrolled people</li>
              <li>Each person gets their own drills, coaching, and Resilience Report</li>
              <li>Great for both parents plus an aunt, uncle, or in-law</li>
              <li>One bill, the best per-person value — about $4.75 per person</li>
            </ul>
            <a class="btn btn--ghost" href="/early-access">Start free trial</a>
            <p class="price-card__trial">Includes 14-day free trial</p>
          </div>
        </div>
        <p class="guarantee center">
          Every plan comes with a <strong>60-day money-back guarantee</strong> — if Spry isn't a
          fit, we refund in full. No questions, no forms.
        </p>
      </div>

      <!-- ============ BUSINESSES ============ -->
      <div class="plans-panel" data-plan="business">
        <div class="pricing-grid pricing-grid--single">
          <div class="price-card">
            <p class="price-card__label">For businesses</p>
            <h2>Communities, agencies &amp; advisors</h2>
            <p class="price-card__price">
              <span class="price-card__num">$4–8</span>/enrolled person per month
            </p>
            <p class="price-card__alt">Volume-based. A 60-resident community ≈ $360/mo · 100 advisory clients ≈ $500/mo ($60/client/year)</p>
            <ul>
              <li>Everything in the Individual plan, for every enrolled person</li>
              <li>Aggregate resilience reporting and a marketing-able community stat</li>
              <li>Co-branded family Resilience Reports</li>
              <li>Enrollment and consent workflow support</li>
              <li>A dedicated onboarding partner</li>
            </ul>
            <p class="price-card__note">
              <strong>Founding-partner pilots:</strong> discounted 90-day pilot for the first cohort of
              communities, agencies, and advisory firms.
            </p>
            <a class="btn btn--ghost" href="mailto:hello@sawtoothtechnologies.com?subject=Spry%20partner%20call">Book a 20-minute call</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--paper">
    <div class="wrap" style="max-width: 800px;">
      <h2 class="center">Pricing questions</h2>
      <div style="margin-top: 30px;">
        <details class="faq-item">
          <summary>Which plan should I choose?</summary>
          <div class="faq-body">
            <p>
              Most families pick <strong>Couples &amp; pairs</strong> — it covers both parents (or
              a couple) on one bill and is our most popular plan. Choose Individual for one person,
              or Family if you're protecting up to four people, like both parents plus an aunt or
              in-law. You can move up a plan anytime.
            </p>
          </div>
        </details>
        <details class="faq-item">
          <summary>Why does this cost more than a call blocker?</summary>
          <div class="faq-body">
            <p>
              A blocker filters some scams. Spry changes what happens when one gets through —
              and one always gets through. You're not buying software; you're buying a skill and
              monthly proof it's growing.
            </p>
          </div>
        </details>
        <details class="faq-item">
          <summary>How does the free trial work?</summary>
          <div class="faq-body">
            <p>
              Every plan starts with a 14-day free trial — long enough to see the first drills and
              coaching in action. And after that, you're still covered by the 60-day money-back
              guarantee.
            </p>
          </div>
        </details>
        <details class="faq-item">
          <summary>What if my parent doesn't want it?</summary>
          <div class="faq-body">
            <p>
              Then we don't enroll them. Consent isn't a checkbox for us; it's the product working
              as designed. Many parents warm up after seeing a sample drill — most people enjoy
              being good at this.
            </p>
          </div>
        </details>
        <details class="faq-item">
          <summary>Contracts?</summary>
          <div class="faq-body">
            <p>None. Monthly plans cancel anytime; annual plans refund unused months.</p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <CtaBand />
</Base>

<script>
  // Plan-type toggle (individuals & families ↔ businesses).
  // Progressive enhancement: without JS the toggle is hidden and both panels render stacked.
  const plans = document.getElementById('plans');
  if (plans) {
    plans.classList.add('plans--js');
    const buttons = Array.from(plans.querySelectorAll('.plans-toggle__btn'));
    const panels = Array.from(plans.querySelectorAll('.plans-panel'));
    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = btn.dataset.panel;
        buttons.forEach((b) => {
          const active = b === btn;
          b.classList.toggle('is-active', active);
          b.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
        panels.forEach((p) => p.classList.toggle('is-active', p.dataset.plan === target));
      });
    });

    // Billing-period toggle (annual ↔ monthly). Swaps the price, billing note, and savings
    // line on every family card. Progressive enhancement: without JS the toggle is hidden and
    // the cards ship annual pricing (with the monthly figure available on request).
    const billing = plans.querySelector('.billing-toggle');
    if (billing) {
      plans.classList.add('billing--js');
      const bBtns = Array.from(billing.querySelectorAll('.billing-toggle__btn'));
      const swappable = Array.from(plans.querySelectorAll('.price-card__num[data-annual], .price-card__billing[data-annual], .price-card__save[data-annual]'));
      const apply = (mode) => {
        swappable.forEach((el) => {
          const val = el.getAttribute('data-' + mode) || '';
          el.textContent = val;
          if (el.classList.contains('price-card__save')) {
            el.style.visibility = val ? 'visible' : 'hidden';
          }
        });
        bBtns.forEach((b) => {
          const active = b.dataset.billing === mode;
          b.classList.toggle('is-active', active);
          b.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
      };
      bBtns.forEach((b) => b.addEventListener('click', () => apply(b.dataset.billing)));
      apply('annual');
    }
  }
</script>

<style>
  .plans-toggle-row { display: flex; justify-content: center; margin-bottom: 24px; }
  .plans-toggle {
    display: none;
    background: var(--paper);
    border: 1.5px solid var(--line);
    border-radius: 999px;
    padding: 5px;
    gap: 4px;
  }
  .plans--js .plans-toggle { display: inline-flex; }
  .plans-toggle__btn {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink-soft);
    background: transparent;
    border: none;
    border-radius: 999px;
    padding: 11px 24px;
    cursor: pointer;
    transition: background 0.12s ease, color 0.12s ease;
  }
  .plans-toggle__btn:hover { color: var(--pine-deep); }
  .plans-toggle__btn:focus-visible { outline: 3px solid var(--amber); outline-offset: 2px; }
  .plans-toggle__btn.is-active {
    background: var(--pine-deep);
    color: var(--cream);
  }

  /* ---------- Billing-period toggle ---------- */
  .billing-toggle-row { display: flex; justify-content: center; margin-bottom: 36px; }
  .billing-toggle {
    display: none;
    background: var(--paper);
    border: 1.5px solid var(--line);
    border-radius: 999px;
    padding: 5px;
    gap: 4px;
  }
  .billing--js .billing-toggle { display: inline-flex; }
  .billing-toggle__btn {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--ink-soft);
    background: transparent;
    border: none;
    border-radius: 999px;
    padding: 9px 20px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.12s ease, color 0.12s ease;
  }
  .billing-toggle__btn:hover { color: var(--pine-deep); }
  .billing-toggle__btn:focus-visible { outline: 3px solid var(--amber); outline-offset: 2px; }
  .billing-toggle__btn.is-active { background: var(--pine-deep); color: var(--cream); }
  .billing-toggle__save {
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--amber-deep);
    letter-spacing: 0.02em;
  }
  .billing-toggle__btn.is-active .billing-toggle__save { color: var(--amber); }

  .plans-panel + .plans-panel { margin-top: 48px; }
  .plans--js .plans-panel { display: none; }
  .plans--js .plans-panel.is-active { display: block; animation: planFade 0.25s ease; }
  .plans--js .plans-panel + .plans-panel { margin-top: 0; }
  @keyframes planFade {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: none; }
  }

  .pricing-grid {
    display: grid;
    gap: 28px;
    align-items: start;
  }
  @media (min-width: 900px) {
    .pricing-grid--family { grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .pricing-grid--single { grid-template-columns: 1fr; max-width: 680px; margin-inline: auto; }
  }
  .price-card {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 38px 32px;
    box-shadow: var(--shadow);
  }
  .price-card--featured {
    border: 2px solid var(--pine);
    box-shadow: var(--shadow-lg);
    position: relative;
  }
  @media (min-width: 900px) {
    .price-card--featured { transform: translateY(-10px); }
  }
  .price-badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--amber);
    color: var(--pine-deep);
    font-weight: 700;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 16px;
    border-radius: 999px;
    white-space: nowrap;
    box-shadow: var(--shadow);
  }
  .price-card__label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--amber-deep);
    margin-bottom: 6px;
  }
  .price-card h2 { margin-bottom: 10px; }
  .price-card__price { font-size: 1.15rem; color: var(--ink-soft); margin-bottom: 2px; }
  .price-card__num {
    font-family: var(--font-display);
    font-size: 3rem;
    font-weight: 700;
    color: var(--pine-deep);
  }
  .price-card__billing {
    color: var(--ink-soft);
    font-size: 0.9rem;
    margin: 0 0 4px;
  }
  .price-card__save {
    color: var(--amber-deep);
    font-weight: 700;
    font-size: 0.88rem;
    margin: 0 0 18px;
    min-height: 1.2em;
  }
  .price-card__alt { color: var(--ink-soft); font-size: 1rem; }
  .price-card ul { padding-left: 1.2em; margin: 0 0 20px; }
  .price-card ul li { margin-bottom: 0.55em; font-size: 1rem; }
  .price-card__note { font-size: 0.95rem; color: var(--ink-soft); margin-bottom: 24px; }
  .price-card__trial {
    font-size: 0.9rem;
    color: var(--ink-soft);
    margin: 10px 0 0;
  }
  .price-card .btn { width: 100%; }
  .guarantee {
    font-size: 0.95rem;
    color: var(--ink-soft);
    margin-top: 32px;
  }
  .guarantee strong { color: var(--pine-deep); }
</style>
